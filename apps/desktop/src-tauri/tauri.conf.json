{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lux IDE",
  "version": "1.0.4",
  "identifier": "dev.lux.ide",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lux IDE",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "appimage", "deb", "rpm"],
    "publisher": "Lux IDE Team",
    "copyright": "Copyright (c) 2026 Lux IDE Team",
    "category": "DeveloperTool",
    "shortDescription": "A Rust-first cross-platform IDE.",
    "longDescription": "Lux IDE is a Rust-first cross-platform integrated development environment built for quality, performance, and a polished desktop experience.",
    "resources": [],
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false,
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "languages": ["English", "Russian"],
        "installerHooks": "installer/windows/lux-installer.nsi"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": []
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      }
    }
  }
}
