{
  "name": "@lux/desktop",
  "version": "1.0.12",
  "license": "Apache-2.0",
  "private": true,
  "description": "Lux IDE desktop application built with Tauri, React, Monaco, and Rust.",
  "repository": {
    "type": "git",
    "url": "https://github.com/GofMan5/lux-ide.git",
    "directory": "apps/desktop"
  },
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/kill-dev-port.mjs 5173 && node ./scripts/start-browser-preview.mjs",
    "build": "pnpm run verify:ai-index && pnpm run verify:ai-prompt && pnpm run verify:ai-tools && pnpm run verify:ai-transport && pnpm run verify:ai-chat-pipeline && pnpm run verify:decode-chat-text && pnpm run verify:ai-chat-persistence && pnpm run test && tsc --noEmit && vite build && pnpm run verify:bundle-budget",
    "compare:ai-agents": "node ./scripts/compare-ai-agents.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "benchmark:ai-agent": "node ./scripts/benchmark-ai-agent.mjs",
    "benchmark:ai-prompt": "node ./scripts/benchmark-ai-prompt.mjs",
    "verify:ai-tools": "node ./scripts/verify-ai-tools.mjs",
    "verify:agent-browser": "node ./scripts/verify-agent-browser-integration.mjs",
    "verify:ai-index": "node ./scripts/verify-ai-index.mjs",
    "verify:ai-prompt": "node ./scripts/verify-ai-prompt.mjs",
    "verify:ai-transport": "node ./scripts/verify-ai-transport.mjs",
    "verify:ai-chat-persistence": "node ./scripts/verify-ai-chat-persistence.mjs",
    "verify:ai-chat-pipeline": "node ./scripts/verify-ai-chat-pipeline.mjs",
    "verify:decode-chat-text": "node ./scripts/verify-decode-chat-text.mjs",
    "verify:bundle-budget": "node ./scripts/verify-bundle-budget.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-virtual": "3.13.26",
    "@tauri-apps/api": "2.11.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "agent-browser": "0.31.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.17.0",
    "marked": "14.0.0",
    "mermaid": "11.15.0",
    "monaco-editor": "0.55.1",
    "motion": "12.40.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-resizable-panels": "4.11.2",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "esbuild": "0.28.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.9"
  }
}
