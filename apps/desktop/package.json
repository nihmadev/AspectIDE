{
  "name": "@lux/desktop",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "private": true,
  "description": "Lux IDE desktop application built with Tauri, React, Monaco, and Rust.",
  "repository": {
    "type": "git",
    "url": "https://github.com/GofMan5/lux-ide.git",
    "directory": "apps/desktop"
  },
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/kill-dev-port.mjs 5173 && vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "pnpm run verify:ai-index && pnpm run verify:ai-prompt && pnpm run verify:ai-tools && tsc --noEmit && vite build",
    "compare:ai-agents": "node ./scripts/compare-ai-agents.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "benchmark:ai-agent": "node ./scripts/benchmark-ai-agent.mjs",
    "benchmark:ai-prompt": "node ./scripts/benchmark-ai-prompt.mjs",
    "verify:ai-tools": "node ./scripts/verify-ai-tools.mjs",
    "verify:ai-index": "node ./scripts/verify-ai-index.mjs",
    "verify:ai-prompt": "node ./scripts/verify-ai-prompt.mjs",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri"
  },
  "dependencies": {
    "@monaco-editor/react": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "latest",
    "@radix-ui/react-tooltip": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-virtual": "latest",
    "@tauri-apps/api": "latest",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cmdk": "latest",
    "lucide-react": "latest",
    "marked": "14.0.0",
    "monaco-editor": "latest",
    "motion": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-resizable-panels": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@tauri-apps/cli": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "esbuild": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
